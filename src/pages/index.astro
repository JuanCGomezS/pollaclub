---
import Layout from '../layouts/Layout.astro';
import HomeGroupsLink from '../components/react/HomeGroupsLink';
import HowItWorks from '../components/react/HowItWorks';
import PricingSection from '../components/PricingSection.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="PollaClub - Sistema de Pronósticos Deportivos" showHeader={true}>
  <main class="min-h-screen bg-[color:var(--pc-surface)] py-10">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center space-y-4">
        <div class="flex justify-center">
          <img src={baseUrl + 'pollaclub.png'} alt="PollaClub" class="h-48 w-auto mx-auto" />
        </div>
        <p class="text-xl text-[color:var(--pc-muted)]/90 mb-4">
          Sistema de pronósticos deportivos
        </p>
        <div class="flex justify-center">
          <HomeGroupsLink client:load />
        </div>
      </div>

      <HowItWorks client:load />
      <PricingSection />
    </div>
  </main>
</Layout>