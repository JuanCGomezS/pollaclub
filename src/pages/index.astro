---
import Layout from '../layouts/Layout.astro';
import HomeGroupsLink from '../components/react/HomeGroupsLink';
import HowItWorks from '../components/react/HowItWorks';
---

<Layout title="PollaClub - Sistema de Pronósticos Deportivos" showHeader={true}>
  <main class="min-h-screen bg-gray-50 flex items-center justify-center">
    <div class="text-center space-y-4">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">
        PollaClub
      </h1>
      <p class="text-xl text-gray-600 mb-4">
        Sistema de pronósticos deportivos entre amigos
      </p>
      <div class="flex justify-center">
        <HomeGroupsLink client:load />
      </div>
      <HowItWorks client:load />
    </div>
  </main>
</Layout>