---
import '../styles/global.css';
import Header from '../components/react/Header';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  showHeader?: boolean;
}

const { title = 'PollaClub', showHeader = true } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es" data-base={baseUrl}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Sistema de pronósticos deportivos entre amigos" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={baseUrl + 'pollaclub.png'} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    {showHeader && <Header client:load />}
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
