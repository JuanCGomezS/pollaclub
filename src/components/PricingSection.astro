---
import { getWhatsappLink } from '../lib/utils';

type PlanCard = {
  tag: string;
  title: string;
  price: string;
  priceBeforeLaunch?: string;
  description: string;
  perParticipant: string;
  idealFor: string;
  marketingLine: string;
  highlighted?: boolean;
};

const plans: PlanCard[] = [
  {
    tag: 'Plan de entrada',
    title: 'Prueba gratis 3 partidos',
    price: '$0 COP',
    description: 'Acceso completo durante los 3 primeros partidos (máximo 5 participantes).',
    perParticipant: 'Gratis',
    idealFor: 'Probar la experiencia real antes de pagar',
    marketingLine: 'Luego puedes actualizar a cualquier plan pago sin perder el progreso del grupo.'
  },
  {
    tag: 'Plan 1-5',
    title: 'Hasta 5 participantes',
    price: '$20.000 COP',
    priceBeforeLaunch: '$30.000 COP',
    description: 'Para grupos pequeños que quieren jugar todo el torneo sin complicaciones.',
    perParticipant: 'desde $4.000 COP',
    idealFor: 'Familia o amigos cercanos',
    marketingLine: 'Menos de lo que cuesta un snack por todo el torneo.'
  },
  {
    tag: 'PLAN 1-15 (Mas elegido)',
    title: 'Hasta 15 participantes',
    price: '$40.000 COP',
    priceBeforeLaunch: '$50.000 COP',
    description: 'El equilibrio ideal entre precio total y costo por persona para la mayoría de grupos.',
    perParticipant: 'desde $2.667 COP',
    idealFor: 'Oficinas, universidades y parches grandes',
    marketingLine: 'Recomendado: mayor diversión por menor costo individual.',
    highlighted: true
  },
  {
    tag: 'Plan 1-30',
    title: 'Hasta 30 participantes',
    price: '$60.000 COP',
    priceBeforeLaunch: '$70.000 COP',
    description: 'Perfecto cuando el grupo crece y quieres mantener todo centralizado en una sola liga.',
    perParticipant: 'desde $2.000 COP',
    idealFor: 'Empresas, comunidades y barrios',
    marketingLine: 'Mientras más jugadores invitas, menos paga cada uno.'
  },
  {
    tag: 'Plan 31-50',
    title: 'De 31 a 50 participantes',
    price: '$80.000 COP',
    priceBeforeLaunch: '$90.000 COP',
    description: 'Pensado para grupos muy activos que quieren mantener una sola competencia bien organizada.',
    perParticipant: 'desde $1.600 COP',
    idealFor: 'Comunidades grandes y torneos internos',
    marketingLine: 'Ticket bajo por persona aun en grupos grandes.'
  },
  {
    tag: 'Plan +50',
    title: 'Mas de 50 participantes',
    price: '$100.000 COP',
    priceBeforeLaunch: '$110.000 COP',
    description: 'Diseñado para grupos masivos que quieren una experiencia seria, ordenada y competitiva.',
    perParticipant: 'hasta $2.000 COP (con 50)',
    idealFor: 'Torneos grandes y comunidades organizadas',
    marketingLine: 'Plan para admins que quieren escalar sin perder control.'
  }
];

const LAUNCH_END_ISO = '2026-05-01T23:59:59-05:00';

function splitPriceDisplay(price: string): { amount: string; suffix: string } {
  const t = price.trim();
  if (t.endsWith(' COP')) {
    return { amount: t.slice(0, -4).trim(), suffix: 'COP' };
  }
  return { amount: t, suffix: '' };
}

function getPlanWhatsappMessage(plan: PlanCard): string {
  return `Hola PollaClub, me interesa el plan ${plan.tag} (${plan.title}).`;
}
---

<section
  id="planes"
  class="mt-12 max-w-6xl mx-auto scroll-mt-[calc(var(--pc-header-height)+0.75rem)]"
>
  <div class="text-center mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-[color:var(--pc-text-on-dark)] mb-3">
      Elige el plan ideal para tu grupo y empieza hoy
    </h2>
    <p class="text-[color:var(--pc-muted)] max-w-3xl mx-auto">
      Todos los planes incluyen exactamente las mismas funcionalidades de PollaClub: pronósticos
      de partidos, bonus, tabla de posiciones en tiempo real y reglas completas de puntuación. Solo
      cambia la cantidad máxima de participantes por grupo.
    </p>
    <p class="mt-4 text-xs text-[color:var(--pc-accent)] font-medium">Precio por grupo. Sin cobros mensuales ni adicionales.</p>
  </div>

  <div
    class="launch-banner relative mb-8 overflow-hidden rounded-2xl border border-[color:var(--pc-accent)]/25 bg-[#0d1628] p-6 md:p-8 shadow-lg shadow-black/20"
  >
    <div
      class="pointer-events-none absolute -right-8 -top-8 h-40 w-40 rounded-full border border-[color:var(--pc-accent)]/10 opacity-40"
      aria-hidden="true"
    />
    <div class="relative flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-xl">
        <p
          class="mb-3 inline-block rounded-md bg-[color:var(--pc-accent)] px-3 py-1 text-[0.65rem] font-bold uppercase tracking-wider text-[color:var(--pc-text-strong)]"
        >
          Descuento de lanzamiento
        </p>
        <h3 class="text-2xl font-bold leading-tight text-[color:var(--pc-text-on-dark)] md:text-3xl">
          Entra con <span class="text-[color:var(--pc-accent)]">precio de lanzamiento</span> antes de que termine la oferta.
        </h3>
        <p class="mt-3 text-sm text-[color:var(--pc-muted)] md:text-base">
          Ahorra <strong class="text-[color:var(--pc-text-on-dark)]">$10.000 COP</strong> en cada plan de pago. La promoción termina el
          <strong class="text-[color:var(--pc-accent)]">1 de mayo de 2026</strong>.
        </p>
      </div>

      <div class="relative flex shrink-0 justify-center lg:justify-end">
        <svg
          class="pointer-events-none absolute left-1/2 top-1/2 h-48 w-48 -translate-x-1/2 -translate-y-1/2 text-[color:var(--pc-accent)] opacity-[0.07]"
          viewBox="0 0 100 100"
          aria-hidden="true"
        >
          <polygon
            points="50,5 61,38 97,38 68,59 79,95 50,73 21,95 32,59 3,38 39,38"
            fill="currentColor"
          />
        </svg>
        <div
          id="launch-countdown"
          class="relative z-10 flex gap-4 sm:gap-6 md:gap-8"
          data-deadline={LAUNCH_END_ISO}
        >
          <div class="flex flex-col items-center">
            <span
              data-unit="days"
              class="tabular-nums text-4xl font-extrabold text-[color:var(--pc-accent)] sm:text-5xl md:text-6xl"
              >--</span
            >
            <span class="mt-1 text-[0.65rem] font-semibold uppercase tracking-widest text-[color:var(--pc-muted)]"
              >Días</span
            >
          </div>
          <div class="flex flex-col items-center">
            <span
              data-unit="hours"
              class="tabular-nums text-4xl font-extrabold text-[color:var(--pc-accent)] sm:text-5xl md:text-6xl"
              >--</span
            >
            <span class="mt-1 text-[0.65rem] font-semibold uppercase tracking-widest text-[color:var(--pc-muted)]"
              >Horas</span
            >
          </div>
          <div class="flex flex-col items-center">
            <span
              data-unit="minutes"
              class="tabular-nums text-4xl font-extrabold text-[color:var(--pc-accent)] sm:text-5xl md:text-6xl"
              >--</span
            >
            <span class="mt-1 text-[0.65rem] font-semibold uppercase tracking-widest text-[color:var(--pc-muted)]"
              >Minutos</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-center mb-8">
    <a
      href={getWhatsappLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-flex w-auto items-center justify-center gap-2 rounded-md bg-[color:var(--pc-accent)] px-4 py-2 font-semibold text-[color:var(--pc-text-strong)] transition hover:bg-[color:var(--pc-accent-dark)]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-5 w-5 shrink-0"
        aria-hidden
      >
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.883 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
      Quiero entrar al juego
    </a>
  </div>

  <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
    {plans.map((plan) => {
      const priceParts = splitPriceDisplay(plan.price);
      return (
          <article
            class={`relative flex h-full min-h-full flex-col rounded-2xl border ${
              plan.highlighted
                ? 'z-10 overflow-visible border-[color:var(--pc-accent)]/40 bg-[#1e293b] shadow-xl shadow-black/35 ring-1 ring-[color:var(--pc-accent)]/25'
                : 'z-0 overflow-hidden border border-white/[0.06] bg-[#111b2d] shadow-lg shadow-black/20'
            }`}
          >
            {plan.highlighted && (
              <>
                <div
                  class="pointer-events-none absolute inset-x-0 top-0 z-0 h-20 rounded-t-2xl bg-gradient-to-b from-[color:var(--pc-accent)]/18 via-[color:var(--pc-accent)]/5 to-transparent"
                  aria-hidden="true"
                />
                <div
                  class="pointer-events-none absolute left-3 right-3 top-0 z-0 h-px bg-gradient-to-r from-transparent via-[color:var(--pc-accent)]/50 to-transparent"
                  aria-hidden="true"
                />
                <span
                  class="absolute left-1/2 top-0 z-10 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[color:var(--pc-text-strong)]/10 bg-[color:var(--pc-accent)] px-4 py-1.5 text-[0.65rem] font-bold uppercase tracking-[0.18em] text-[color:var(--pc-text-strong)] shadow-lg shadow-black/30"
                >
                  Recomendado
                </span>
              </>
            )}
            <div
              class={`flex min-h-0 flex-1 flex-col px-6 pb-6 md:px-8 md:pb-8 ${
                plan.highlighted ? 'pt-11 md:pt-12' : 'pt-10 md:pt-12'
              }`}
            >
            <p
              class={`mb-2 text-[0.65rem] font-bold uppercase tracking-[0.2em] ${
                plan.highlighted ? 'text-[color:var(--pc-accent)]' : 'text-white/90'
              }`}
            >
              {plan.tag}
            </p>
            <h3 class="mb-4 text-lg font-bold leading-snug text-[color:var(--pc-text-on-dark)] md:text-xl">
              {plan.title}
            </h3>

            <div class="mb-4">
              {plan.priceBeforeLaunch && (
                <p class="mb-1 text-sm text-[color:var(--pc-muted)] line-through decoration-[color:var(--pc-muted)]/70">
                  {plan.priceBeforeLaunch}
                </p>
              )}
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0">
                <span class="text-3xl font-extrabold tracking-tight text-[color:var(--pc-text-on-dark)] md:text-4xl">
                  {priceParts.amount}
                </span>
                {priceParts.suffix && (
                  <span class="text-sm font-medium text-[color:var(--pc-muted)]">{priceParts.suffix}</span>
                )}
              </div>
            </div>

            <p class="mb-6 text-sm leading-relaxed text-[color:var(--pc-muted)]">{plan.description}</p>

            <ul class="mb-6 flex flex-1 flex-col gap-3 text-sm text-[color:var(--pc-muted)]">
              <li class="flex gap-3">
                <span
                  class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[color:var(--pc-accent)] text-[color:var(--pc-text-strong)]"
                  aria-hidden="true"
                >
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 6l2.5 2.5L9.5 3.5" />
                  </svg>
                </span>
                <span>
                  <span class="font-semibold text-[color:var(--pc-text-on-dark)]">Por participante:</span>{' '}
                  {plan.perParticipant}
                </span>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[color:var(--pc-accent)] text-[color:var(--pc-text-strong)]"
                  aria-hidden="true"
                >
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 6l2.5 2.5L9.5 3.5" />
                  </svg>
                </span>
                <span>
                  <span class="font-semibold text-[color:var(--pc-text-on-dark)]">Ideal para:</span> {plan.idealFor}
                </span>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[color:var(--pc-accent)] text-[color:var(--pc-text-strong)]"
                  aria-hidden="true"
                >
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 6l2.5 2.5L9.5 3.5" />
                  </svg>
                </span>
                <span>{plan.marketingLine}</span>
              </li>
            </ul>

            <a
              href={getWhatsappLink(getPlanWhatsappMessage(plan))}
              target="_blank"
              rel="noopener noreferrer"
              class={`mt-auto inline-flex w-full items-center justify-center rounded-full px-4 py-3 text-sm font-semibold transition ${
                plan.highlighted
                  ? 'bg-[color:var(--pc-accent)] text-[color:var(--pc-text-strong)] shadow-md hover:bg-[color:var(--pc-accent-dark)]'
                  : 'border border-white/20 text-[color:var(--pc-text-on-dark)] hover:border-[color:var(--pc-accent)]/45 hover:bg-white/[0.04]'
              }`}
            >
              Quiero este plan
            </a>
            </div>
          </article>
      );
    })}
  </div>

  <div class="flex justify-center mb-8">
    <a
      href={getWhatsappLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-flex w-auto items-center justify-center gap-2 rounded-md bg-[color:var(--pc-accent)] px-4 py-2 font-semibold text-[color:var(--pc-text-strong)] transition hover:bg-[color:var(--pc-accent-dark)]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-5 w-5 shrink-0"
        aria-hidden
      >
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.883 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
      Quiero entrar al juego
    </a>
  </div>

  <div class="mt-6 rounded-xl border border-[color:var(--pc-main-dark)]/60 bg-[color:var(--pc-surface)]/70 p-4 text-sm text-[color:var(--pc-muted)]">
    <p class="font-semibold text-[color:var(--pc-text-on-dark)] mb-2">Como funciona el pago manual</p>
    <ul class="list-disc list-inside space-y-1">
      <li>Revisas los planes arriba y pulsas el botón "Quiero entrar al juego" para escribirnos por WhatsApp.</li>
      <li>Te compartimos el valor y los datos de pago por Nequi o llaves Bre-B.</li>
      <li>Cuando pagues, nos envias comprobante y tu correo de registro en PollaClub.</li>
      <li>En un tiempo aproximado de 10 minutos, tendras acceso a crear tu grupo y podras empezar a jugar.</li>
      <li>Si estás en plan gratuito, puedes actualizar a cualquier plan cuando quieras.</li>
      <li>Tenemos soporte por WhatsApp para cualquier duda o inconveniente durante la activación.</li>
    </ul>
  </div>
</section>

<script is:inline>
  (function () {
    var root = document.getElementById('launch-countdown');
    if (!root) return;
    var deadline = root.getAttribute('data-deadline');
    if (!deadline) return;

    function pad(n) {
      return n < 10 ? '0' + n : String(n);
    }

    function tick() {
      var end = new Date(deadline).getTime();
      var now = Date.now();
      var ms = Math.max(0, end - now);
      var totalSec = Math.floor(ms / 1000);
      var days = Math.floor(totalSec / 86400);
      var hours = Math.floor((totalSec % 86400) / 3600);
      var minutes = Math.floor((totalSec % 3600) / 60);

      var dEl = root.querySelector('[data-unit="days"]');
      var hEl = root.querySelector('[data-unit="hours"]');
      var mEl = root.querySelector('[data-unit="minutes"]');
      if (dEl) dEl.textContent = String(days);
      if (hEl) hEl.textContent = pad(hours);
      if (mEl) mEl.textContent = pad(minutes);
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>
