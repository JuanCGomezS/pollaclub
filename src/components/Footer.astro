---
const currentYear = new Date().getFullYear();
---

<footer class="mt-16 border-t border-[color:var(--pc-main-dark)]/60 bg-[color:var(--pc-surface)]/95">
  <div class="max-w-6xl mx-auto px-4 py-6 text-center">
    <p class="text-sm text-[color:var(--pc-muted)]">
      © {currentYear} <span class="font-semibold text-[color:var(--pc-accent)]">Juan Gomez</span>. Todos los derechos reservados.
    </p>
    <p class="text-xs text-[color:var(--pc-muted)]/80 mt-2">
      PollaClub · Sistema de pronósticos deportivos
    </p>
  </div>
</footer>
